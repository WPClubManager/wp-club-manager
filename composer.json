{
  "name": "wp-club-manager/wp-club-manager",
  "description": "WP Club Manager is easy to set-up and has everything you need to build and manage an amazing sports club website with WordPress.",
  "keywords": [
    "wordpress"
  ],
  "homepage": "https://wpclubmanager.com",
  "authors": [
    {
      "name": "WP Club Manager",
      "email": "hello@wpclubmanager.com"
    }
  ],
  "require": {
    "php": ">=7.4"
  },
  "require-dev": {
    "dealerdirect/phpcodesniffer-composer-installer": "^1.0",
    "wp-coding-standards/wpcs": "^3.0.0",
    "lucatume/wp-browser": "^3.5",
    "phpstan/phpstan": "^1.10",
    "szepeviktor/phpstan-wordpress": "^1.3",
    "behat/gherkin": "^4.9.0 <4.10"
  },
  "config": {
    "allow-plugins": {
      "dealerdirect/phpcodesniffer-composer-installer": true
    }
  },
  "scripts": {
    "test": "vendor/bin/codecept run wpunit",
    "cs": "vendor/bin/phpcs",
    "analyse": "vendor/bin/phpstan analyse"
  }
}
